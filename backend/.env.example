# Copy this to .env and fill in your values
# NEVER commit .env to git

# Database (Render PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/doubtmap

# Groq LLM API (get free key at console.groq.com)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# Pinecone Vector DB (get free key at app.pinecone.io)
PINECONE_API_KEY=pcsk_xxxxxxxxxxxxxxxxxxxx
PINECONE_INDEX_NAME=doubtmap-syllabus

# App Config
APP_ENV=development
CORS_ORIGINS=http://localhost:3000,https://doubtmap.vercel.app

# n8n Webhook Secret (share this value with Laptop 3)
N8N_WEBHOOK_SECRET=change-this-to-a-random-secret
